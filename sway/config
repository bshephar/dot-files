### Variables
set $mainMod Mod4
set $terminal alacritty
set $fileManager nautilus
set $menu rofi -show drun

### Output Configuration
# Note: Sway uses fractional scaling differently; 1.25 is supported.
output DP-1 res 3840x2160@60Hz pos 0 0 scale 1.25
output eDP-1 res 2560x1600@120Hz pos 3072 0 scale 1.25

### Environment & Autostart
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec systemctl --user start sway-session.target
exec gnome-keyring-daemon --start --components=secrets
exec swayidle -w \
    timeout 300 'swaylock -f -i "/home/bshephar/Firefox Developer Edition_wallpaper.png"' \
    before-sleep 'swaylock -f -i "/home/bshephar/Firefox Developer Edition_wallpaper.png"'

# Wallpaper (Sway has built-in wallpaper support, but you can use swaybg)
exec swaybg -i "/home/bshephar/Firefox Developer Edition_wallpaper.png" -m fill

### General Appearance
default_border pixel 1
gaps inner 2
gaps outer 4
smart_borders on

# Colors (Sway uses hex, converted from your rgba)
# client.<class>          border  bg      text    indicator child_border
client.focused          #33ccff #33ccff #ffffff #00ff99   #33ccff
client.focused_inactive #595959 #595959 #ffffff #595959   #595959
client.unfocused        #595959 #595959 #ffffff #595959   #595959

### Input Configuration
input type:touchpad {
    tap enabled
    natural_scroll enabled
}

input type:keyboard {
    xkb_layout us
}

input "epic-mouse-v1" {
    pointer_accel -0.5
}

### Keybindings
bindsym $mainMod+Q exec $terminal
bindsym $mainMod+C kill
bindsym $mainMod+M exit
bindsym $mainMod+E exec $fileManager
bindsym $mainMod+V floating toggle
bindsym $mainMod+R exec $menu
bindsym $mainMod+L exec pactl set-sink-mute @DEFAULT_SINK@ 1 && swaylock

# Focus
bindsym $mainMod+left focus left
bindsym $mainMod+right focus right
bindsym $mainMod+up focus up
bindsym $mainMod+down focus down

# Workspaces
bindsym $mainMod+1 workspace number 1
bindsym $mainMod+2 workspace number 2
bindsym $mainMod+3 workspace number 3
bindsym $mainMod+4 workspace number 4
bindsym $mainMod+5 workspace number 5
bindsym $mainMod+6 workspace number 6
bindsym $mainMod+7 workspace number 7
bindsym $mainMod+8 workspace number 8
bindsym $mainMod+9 workspace number 9
bindsym $mainMod+0 workspace number 10

# Move to Workspace
bindsym $mainMod+Shift+1 move container to workspace number 1
bindsym $mainMod+Shift+2 move container to workspace number 2
bindsym $mainMod+Shift+3 move container to workspace number 3
bindsym $mainMod+Shift+4 move container to workspace number 4
bindsym $mainMod+Shift+5 move container to workspace number 5
bindsym $mainMod+Shift+6 move container to workspace number 6
bindsym $mainMod+Shift+7 move container to workspace number 7
bindsym $mainMod+Shift+8 move container to workspace number 8
bindsym $mainMod+Shift+9 move container to workspace number 9
bindsym $mainMod+Shift+0 move container to workspace number 10

# Scratchpad (Special Workspace equivalent)
bindsym $mainMod+S scratchpad show
bindsym $mainMod+Shift+S move scratchpad

# Media Keys
bindsym XF86AudioRaiseVolume exec wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym XF86MonBrightnessUp exec brightnessctl -d "intel_backlight" -e4 -n2 set 5%+
bindsym XF86MonBrightnessDown exec brightnessctl -d "intel_backlight" -e4 -n2 set 5%-

# Screenshot
bindsym Print exec grim -g "$(slurp)" - | wl-copy
bindsym $mainMod+Shift+F6 exec grim -g "$(slurp)" - | wl-copy && notify-send "Screenshot Copied"

# Waybar toggle
bindsym $mainMod+Shift+B exec killall waybar
bindsym $mainMod+B exec waybar

bindgesture swipe:right workspace prev
bindgesture swipe:left workspace next
### Window Rules
for_window [app_id=".*"] inhibit_idle fullscreen
for_window [class=".*"] inhibit_idle fullscreen
for_window [class=".*"] border pixel 1
